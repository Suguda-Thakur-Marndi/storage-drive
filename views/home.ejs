<!doctype html>
<html>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Home</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Fraunces:opsz,wght@9..144,600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/style.css" />

</head>

<body class="page-home">
<main class="home-shell">
	<header class="home-topbar">
		<div>
			<h1 class="home-brand">Vault Dashboard</h1>
			<span class="home-badge">Welcome <%= username || 'User' %></span>
		</div>

		<div class="home-actions">
			<button type="button" onclick="openPopup()" class="home-btn home-btn-primary">Upload File</button>
			<form action="/user/logout" method="post">
				<button type="submit" class="home-btn home-btn-dark">Logout</button>
			</form>
		</div>
	</header>

	<section class="home-panel">
		<h2>Your Uploaded Files</h2>

		<% if (files && files.length > 0) { %>
			<div class="home-grid">
				<% files.forEach(function(file) { %>
					<article class="home-file-card">
						<div class="home-file-meta">
							<p class="home-file-name"><%= file.originalName %></p>
							<p class="home-file-size"><%= Math.ceil(file.size / 1024) %> KB</p>
						</div>
						<a href="/user/files/<%= file._id %>/download" class="home-download">Download</a>
					</article>
				<% }) %>
			</div>
		<% } else { %>
			<p class="home-empty">No files uploaded yet. Start by uploading your first file.</p>
		<% } %>
	</section>
</main>

<div id="popup" class="home-modal">
	<form action="/user/home" method="post" enctype="multipart/form-data" class="home-sheet">
		<div class="home-sheet-top">
			<strong>Upload New File</strong>
			<button type="button" class="home-close" onclick="closePopup()">✕</button>
		</div>

		<div class="home-drop">
			<p>Choose a file from your device</p>
			<p class="home-file-size">Maximum file size: 30MB</p>
			<button type="button" class="home-btn home-btn-primary" onclick="document.getElementById('file').click()">Browse File</button>
			<p id="fileNamePreview" class="home-file-name-preview">No file selected</p>
			<input id="file" type="file" class="home-hidden-input" name="files" required />
		</div>

		<div class="home-sheet-actions">
			<button type="button" class="home-btn home-btn-dark" onclick="closePopup()">Cancel</button>
			<button type="submit" class="home-btn home-btn-primary">Upload</button>
		</div>
	</form>
</div>

<script>
function openPopup(){
document.getElementById("popup").classList.add("open");
}

function closePopup(){
document.getElementById("popup").classList.remove("open");
}

document.getElementById('file').addEventListener('change', function (event) {
const selected = event.target.files && event.target.files[0] ? event.target.files[0].name : 'No file selected';
document.getElementById('fileNamePreview').textContent = selected;
});
</script>

</body>
</html>